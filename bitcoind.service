[Unit]
Description=Bigcoin BGC Node
After=network.target

[Service]
Type=forking
User=root
ExecStart=/usr/local/bin/bitcoind
ExecStop=/usr/local/bin/bitcoin-cli -rpcuser=bigcoinrpc -rpcpassword=Bigcoin@2026 stop
Restart=on-failure
RestartSec=30
TimeoutStartSec=120
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
